{
  "name": "secure-interview",
  "version": "1.0.0",
  "description": "LetsHyre Secure Interview Application",
  "main": "main.js",
  "author": "LetsHyre",
  "private": true,
  "scripts": {
    "start": "nodemon --watch . --exec electron .",
    "build:agent": "python scripts/build_agent.py",
    "build": "electron-builder",
    "build:full": "npm run build:agent && electron-builder",
    "dist": "electron-builder --win --mac"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "node-fetch": "^2.6.7",
    "electron-updater": "^6.1.8"
  },
  "build": {
    "appId": "com.letshyre.secure",
    "productName": "LetsHyre Secure Interview",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "letshyre",
        "repo": "secure-interview-releases"
      }
    ],
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "resources/agent.exe",
        "to": "agent.exe",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!node_modules/.cache"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "protocols": [
      {
        "name": "LetsHyre Protocol",
        "schemes": [
          "letshyre"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LetsHyre Secure Interview"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.education",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "extraResources": [
        {
          "from": "resources/agent",
          "to": "agent",
          "filter": ["**/*"]
        }
      ]
    }
  }
}
