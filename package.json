{
  "name": "letshyre-secure-interview",
  "version": "1.0.0",
  "description": "LetsHyre Secure Interview Application",
  "main": "main.js",
  "author": "LetsHyre",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch src --watch assets --watch preload.js --ext js,html,css --exec \"electron .\"",
    "build:agent": "python scripts/build_agent.py",
    "build": "electron-builder",
    "build:full": "npm run build:agent && electron-builder",
    "dist": "electron-builder --win --mac",
    "lint": "eslint src preload.js main.js --ext .js",
    "lint:fix": "eslint src preload.js main.js --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\" \"assets/**/*.{html,css}\" \"preload.js\" \"main.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"assets/**/*.{html,css}\" \"preload.js\" \"main.js\""
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.57.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "electron-updater": "^6.1.8",
    "node-fetch": "^2.6.7"
  },
  "build": {
    "appId": "com.letshyre.secure",
    "productName": "LetsHyre Secure Interview",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "ShivajiVS",
        "repo": "letshre-electron-app"
      }
    ],
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "resources/agent.exe",
        "to": "agent.exe",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!node_modules/.cache"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "protocols": [
      {
        "name": "LetsHyre Protocol",
        "schemes": [
          "letshyre"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LetsHyre Secure Interview"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.education",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "extraResources": [
        {
          "from": "resources/agent",
          "to": "agent",
          "filter": [
            "**/*"
          ]
        }
      ]
    }
  }
}
